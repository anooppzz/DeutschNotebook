{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Exercise",
  "type": "object",
  "required": ["id", "type", "prompt", "version"],
  "properties": {
    "version": { "type": "string" },
    "id": { "type": "string" },
    "type": { "type": "string", "enum": ["multiple_choice", "fill_blank", "drag_drop", "ordering", "listening", "speaking"] },
    "prompt": { "type": "string" },
    "payload": { "type": "object" },
    "options": { "type": "array", "items": { "type": "string" } },
    "answer": {},
    "hints": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "scoring": {
      "type": "object",
      "properties": {
        "points": { "type": "number" },
        "time_limit_seconds": { "type": "number" }
      }
    }
  }
}
