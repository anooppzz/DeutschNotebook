{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lesson",
  "type": "object",
  "required": ["id", "title", "level", "sections", "version"],
  "properties": {
    "version": { "type": "string" },
    "id": { "type": "string" },
    "title": { "type": "string" },
    "level": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
    "category": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "dependsOn": { "type": "array", "items": { "type": "string" } },
    "related": { "type": "array", "items": { "type": "string" } },
    "estimatedTime": { "type": "number" },
    "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string" },
          "title": { "type": "string" },
          "text": { "type": "string" },
          "examples": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["text"],
              "properties": {
                "text": { "type": "string" },
                "translation": { "type": "string" },
                "audio": { "type": "string" }
              }
            }
          },
          "imageId": { "type": "string" },
          "exerciseId": { "type": "string" }
        }
      }
    },
    "vocabulary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "word"],
        "properties": {
          "id": { "type": "string" },
          "word": { "type": "string" },
          "article": { "type": "string" },
          "plural": { "type": "string" },
          "audio": { "type": "string" },
          "image": { "type": "string" }
        }
      }
    },
    "exercises": { "type": "array", "items": { "type": "string" } },
    "metadata": { "type": "object" }
  }
}
